#!/bin/bash

set -x -e

# Fetch Docker Compose setup
cd /root
curl -sSLf -o gcp.zip https://github.com/MRegterschot/gocontrolpanel/archive/refs/heads/dev.zip
rm -rf gocontrolpanel-dev
unzip -o gcp.zip
cd gocontrolpanel-dev/hetzner

COMPOSE_FILES="-f docker-compose.yml"
export COMPOSE_PROJECT_NAME='{{{stack_name}}}'

# Set environment variables
export TM_MASTERSERVER_LOGIN='{{{dedi_login}}}'
export TM_MASTERSERVER_PASSWORD='{{{dedi_password}}}'
export TM_SERVER_PASSWORD='{{{room_password}}}'
# Try to get public IP via DNS
TM_SYSTEM_FORCE_IP_ADDRESS=$(dig +short myip.opendns.com @resolver1.opendns.com)

# Fallback to local interface IP if DNS fails
if [ -z "$TM_SYSTEM_FORCE_IP_ADDRESS" ]; then
    echo "Warning: Could not get public IP via DNS, using local interface IP"
    TM_SYSTEM_FORCE_IP_ADDRESS=$(ip -4 addr show scope global | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | head -n1)
fi

export TM_SYSTEM_FORCE_IP_ADDRESS
export TM_AUTHORIZATION_SUPERADMIN_PASSWORD='{{{superadmin_password}}}'
export TM_AUTHORIZATION_ADMIN_PASSWORD='{{{admin_password}}}'
export TM_AUTHORIZATION_USER_PASSWORD='{{{user_password}}}'
export FM_PASSWORD='{{{filemanager_password}}}'
export TM_PORT='{{{port}}}'
export TM_XMLRPC_PORT='{{{xmlrpc_port}}}'
export FM_PORT='{{{fm_port}}}'

# Start server
docker compose $COMPOSE_FILES up -d
