#!/bin/bash

set -x -e

apt update
apt install -y docker.io docker-compose-v2 curl unzip dnsutils

cd /root
curl -sSLf -o gcp.zip https://github.com/MRegterschot/gocontrolpanel/archive/refs/heads/master.zip
unzip gcp.zip
cd gocontrolpanel-master/hetzner

STACK_DIR="/root/gocontrolpanel-master/hetzner/{{{stack_name}}}"
ENV_FILE="$STACK_DIR/.env"
mkdir -p "$(dirname "$ENV_FILE")"

COMPOSE_DIR="/root/gocontrolpanel-master/hetzner/{{{server_controller.type}}}"
COMPOSE_FILES="-f $COMPOSE_DIR/docker-compose.yml"

TM_SYSTEM_FORCE_IP_ADDRESS=$(dig +short myip.opendns.com @resolver1.opendns.com)

if [ -z "$TM_SYSTEM_FORCE_IP_ADDRESS" ]; then
    echo "Warning: Could not get public IP via DNS, using local interface IP"
    TM_SYSTEM_FORCE_IP_ADDRESS=$(ip -4 addr show scope global | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | head -n1)
fi

cat > "$ENV_FILE" <<'EOF'
COMPOSE_PROJECT_NAME={{{stack_name}}}
TM_MASTERSERVER_LOGIN={{{dedi_login}}}
TM_MASTERSERVER_PASSWORD={{{dedi_password}}}
TM_SERVER_PASSWORD={{{room_password}}}
TM_AUTHORIZATION_SUPERADMIN_PASSWORD={{{superadmin_password}}}
TM_AUTHORIZATION_ADMIN_PASSWORD={{{admin_password}}}
TM_AUTHORIZATION_USER_PASSWORD={{{user_password}}}
FM_PASSWORD={{{filemanager_password}}}
TM_PORT={{{port}}}
TM_XMLRPC_PORT={{{xmlrpc_port}}}
FM_PORT={{{fm_port}}}
EOF

cat >> "$ENV_FILE" <<EOF
TM_SYSTEM_FORCE_IP_ADDRESS=${TM_SYSTEM_FORCE_IP_ADDRESS}
EOF

{{#if server_controller}}
{{#if server_controller.type}}
cat >> "$ENV_FILE" <<'EOF'
DB_HOST={{{db.host}}}
DB_PORT={{{db.port}}}
DB_NAME={{{db.name}}}
DB_USER={{{db.user}}}
DB_PASSWORD={{{db.password}}}
DB_ROOT_PASSWORD={{{db.root_password}}}
EOF

{{#if db.local}}
sed -i "s/^DB_HOST=.*/DB_HOST={{{db.type}}}/" "$ENV_FILE"

COMPOSE_FILES="$COMPOSE_FILES -f /root/gocontrolpanel-master/hetzner/docker-configs/docker-compose.{{{db.type}}}.yml"
{{/if}}
{{/if}}

{{#if (eq server_controller.type "evosc")}}
{{/if}}

{{#if (eq server_controller.type "maniacontrol")}}
cat >> "$ENV_FILE" <<'EOF'
MC_ADMINS={{{server_controller.admins}}}
EOF
{{/if}}

{{#if (eq server_controller.type "minicontrol")}}
cat >> "$ENV_FILE" <<'EOF'
MINI_ADMINS={{{server_controller.admins}}}
MINI_EXCLUDED_PLUGINS={{{server_controller.excludedPlugins}}}
MINI_CONTACT_INFO={{{server_controller.contactInfo}}}
MINI_IDENTIFIER={{{server_controller.identifier}}}
MINI_SECRET={{{server_controller.secret}}}
EOF
{{/if}}

{{#if (eq server_controller.type "pyplanet")}}
cat >> "$ENV_FILE" <<'EOF'
PY_ADMINS={{{server_controller.admins}}}
EOF
{{/if}}
{{/if}}

docker compose \
  --env-file "$ENV_FILE" \
  $COMPOSE_FILES \
  up -d

cat > "$STACK_DIR/restart.sh" <<EOF
#!/bin/bash
set -e

docker compose \
  --env-file "$ENV_FILE" \
  $COMPOSE_FILES \
  up -d
EOF

chmod +x "$STACK_DIR/restart.sh"

cat > "$STACK_DIR/down.sh" <<EOF
#!/bin/bash
set -e

docker compose \
  --env-file "$ENV_FILE" \
  $COMPOSE_FILES \
  down
EOF

chmod +x "$STACK_DIR/down.sh"